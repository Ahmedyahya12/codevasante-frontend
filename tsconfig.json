{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    "types": ["vite/client"],
    "skipLibCheck": true,
    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  },

  "include": ["src"],

  "exclude": ["src/**/*.copy.ts", "src/**/*.copy.tsx", "src/**/* copy.ts", "src/**/* copy.tsx"]
}
